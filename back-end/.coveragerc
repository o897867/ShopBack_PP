# Coverage.py configuration

[run]
source = .
omit =
    */tests/*
    */venv/*
    */.venv/*
    */site-packages/*
    */__pycache__/*
    */conftest.py
    */test_*.py
    */migrations/*
    */legacy/*
branch = True

[report]
precision = 2
show_missing = True
skip_covered = False

exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod
    @overload
    class .*\bProtocol\):
    @(abc\.)?abstractmethod

[html]
directory = htmlcov

[xml]
output = coverage.xml
